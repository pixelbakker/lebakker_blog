---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
  description: string;
  tags: string[];
}

const { title, date, description, tags } = Astro.props;
const base = import.meta.env.BASE_URL;

const formattedDate = date.toLocaleDateString('nb-NO', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---
<Base title={title} description={description}>
  <article>
    <header class="post-header">
      <h1>{title}</h1>
      <div class="post-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {tags.length > 0 && (
          <ul class="tags">
            {tags.map((tag) => (
              <li>
                <a href={`${base}tags/${tag}`}>{tag}</a>
              </li>
            ))}
          </ul>
        )}
      </div>
    </header>
    <div class="post-body">
      <slot />
    </div>
  </article>
</Base>

<style>
  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  h1 {
    font-size: 1.75rem;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .tags {
    list-style: none;
    display: flex;
    gap: 0.5rem;
  }

  .tags a {
    color: var(--color-muted);
    font-size: 0.85rem;
    text-decoration: none;
    border: 1px solid var(--color-border);
    padding: 0.1em 0.55em;
    border-radius: 3px;
  }

  .tags a:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .post-body :global(h2) {
    font-size: 1.35rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
  }

  .post-body :global(h3) {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 1.75rem 0 0.5rem;
  }

  .post-body :global(p) {
    margin-bottom: 1.25rem;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .post-body :global(li) {
    margin-bottom: 0.35rem;
  }

  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.25rem;
    margin: 1.75rem 0;
    color: var(--color-muted);
    font-style: italic;
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }
</style>
