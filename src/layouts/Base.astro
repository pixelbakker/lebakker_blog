---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'En personlig blogg om det opplyste liv.' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header>
      <a href={base} class="site-name">Leif Arne Bakker</a>
      <nav>
        <a href={base}>Innlegg</a>
        <a href={`${base}/tags`}>Tags</a>
        <a href={`${base}/om-meg`}>Om meg</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <span>Leif Arne Bakker &mdash; {new Date().getFullYear()}</span>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --color-bg:      #f5f0e8;
    --color-surface: #ede8dc;
    --color-text:    #2c2416;
    --color-muted:   #7a6e5f;
    --color-accent:  #8b5e3c;
    --color-border:  #d4cdc0;
    --font-serif:    'Lora', Georgia, serif;
    --font-mono:     'JetBrains Mono', 'Fira Code', monospace;
    --measure:       68ch;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    line-height: 1.75;
  }

  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    padding: 0 1.5rem;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    max-width: var(--measure);
    margin: 0 auto;
    width: 100%;
    padding: 2rem 0 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .site-name {
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--color-text);
    text-decoration: none;
  }

  nav {
    display: flex;
    gap: 1.5rem;
  }

  nav a {
    color: var(--color-muted);
    text-decoration: none;
    font-size: 0.95rem;
  }

  nav a:hover {
    color: var(--color-accent);
  }

  main {
    flex: 1;
    max-width: var(--measure);
    width: 100%;
    margin: 0 auto;
    padding: 3rem 0;
  }

  footer {
    max-width: var(--measure);
    width: 100%;
    margin: 0 auto;
    padding: 1.5rem 0 2rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-muted);
    font-size: 0.875rem;
  }

  a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    background: var(--color-surface);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }

  pre {
    font-family: var(--font-mono);
    background: var(--color-surface);
    padding: 1.25rem;
    overflow-x: auto;
    border-radius: 4px;
    line-height: 1.6;
    margin: 1.75rem 0;
  }

  pre code {
    background: none;
    padding: 0;
    font-size: 0.875rem;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }
</style>
