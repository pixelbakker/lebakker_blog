---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allPosts = await getCollection('posts', ({ data }) => !data.draft);

const tagCounts = allPosts.flatMap((post) => post.data.tags).reduce(
  (acc, tag) => {
    acc[tag] = (acc[tag] ?? 0) + 1;
    return acc;
  },
  {} as Record<string, number>
);

const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---
<Base title="Tags – Leif Arne Bakker" description="Alle tags brukt på bloggen.">
  <h1 class="page-title">Tags</h1>
  <ul class="tag-list">
    {tags.map(([tag, count]) => (
      <li>
        <a href={`${base}/tags/${tag}`} class="tag-item">
          <span class="tag-name">{tag}</span>
          <span class="tag-count">{count}</span>
        </a>
      </li>
    ))}
  </ul>
</Base>

<style>
  .page-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 2rem;
  }

  .tag-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .tag-list li + li {
    border-top: 1px solid var(--color-border);
  }

  .tag-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.9rem 0;
    text-decoration: none;
    color: var(--color-text);
  }

  .tag-item:hover .tag-name {
    color: var(--color-accent);
  }

  .tag-name {
    font-size: 1rem;
    font-weight: 600;
    transition: color 0.1s;
  }

  .tag-name::before {
    content: '#';
    color: var(--color-muted);
    font-weight: 400;
    margin-right: 0.1em;
  }

  .tag-count {
    color: var(--color-muted);
    font-size: 0.875rem;
  }
</style>
