---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title="Leif Arne Bakker">
  <ul class="post-list">
    {posts.map((post) => {
      const date = post.data.date.toLocaleDateString('nb-NO', {
        day: 'numeric',
        month: 'long',
        year: 'numeric',
      });
      return (
        <li class="post-item">
          <a href={`${base}/posts/${post.id.replace(/\.mdx?$/, '')}`} class="post-link">
            <h2 class="post-title">{post.data.title}</h2>
            <p class="post-description">{post.data.description}</p>
          </a>
          <div class="post-footer">
            <time class="post-date" datetime={post.data.date.toISOString()}>{date}</time>
            {post.data.tags.length > 0 && (
              <ul class="tags">
                {post.data.tags.map((tag) => (
                  <li><a href={`${base}/tags/${tag}`} class="tag">{tag}</a></li>
                ))}
              </ul>
            )}
          </div>
        </li>
      );
    })}
    {posts.length === 0 && (
      <li class="empty">Ingen innlegg ennå.</li>
    )}
  </ul>
</Base>

<style>
  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-item + .post-item {
    border-top: 1px solid var(--color-border);
  }

  .post-link {
    display: block;
    padding: 1.75rem 0 0.6rem;
    text-decoration: none;
    color: inherit;
  }

  .post-link:hover .post-title {
    color: var(--color-accent);
  }

  .post-title {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
    transition: color 0.1s;
  }

  .post-description {
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  .post-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding-bottom: 1.75rem;
  }

  .post-date {
    color: var(--color-muted);
    font-size: 0.85rem;
  }

  .tags {
    list-style: none;
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    color: var(--color-muted);
    font-size: 0.8rem;
    border: 1px solid var(--color-border);
    padding: 0.1em 0.5em;
    border-radius: 3px;
    text-decoration: none;
  }

  .tag:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .empty {
    color: var(--color-muted);
    padding: 2rem 0;
  }
</style>
